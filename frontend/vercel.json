{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://pms2-production.up.railway.app/api/:path*"
    },
    {
      "source": "/((?!static|icons|manifest.json|favicon.ico|logo).*)",
      "destination": "/index.html"
    }
  ]
}
