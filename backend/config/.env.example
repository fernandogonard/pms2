# ============================================================
# CRM Hotelero — Variables de entorno
# Copiar este archivo como: backend/config/.env
# ============================================================

# --- Base de datos ---
MONGO_URI=mongodb://localhost:27017/crm-hotelero
# En producción (MongoDB Atlas):
# MONGO_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/crm-hotelero?retryWrites=true&w=majority

# --- Servidor ---
PORT=5000
NODE_ENV=development
# NODE_ENV=production

# --- Autenticación JWT ---
JWT_SECRET=cambia_este_secreto_por_uno_seguro_en_produccion
JWT_EXPIRES_IN=7d

# --- CORS ---
# En desarrollo (permite React dev server)
CORS_ORIGIN=http://localhost:3000
# En producción (URL de tu frontend desplegado)
# CORS_ORIGIN=https://mi-hotel.vercel.app

# --- WebSocket ---
# Nivel de logging de WebSocket: debug|info|warn|error
WS_LOG_LEVEL=warn

# --- Logs ---
LOG_LEVEL=info
# LOG_LEVEL=debug  (más detallado, solo para desarrollo)

# --- Rate Limiting (opcional, usa defaults si no se define) ---
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=1000
